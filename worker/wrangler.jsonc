{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nezha-contact",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["nodejs_compat"],
  "send_email": [
    {
      "name": "EMAIL"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://pearlmachine.com"
  },
  "routes": [
    {
      "pattern": "contact.pearlmachine.com",
      "custom_domain": true
    }
  ]
}
